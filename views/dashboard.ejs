<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;700&family=Manrope:wght@400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/styles/main.css">
</head>
<body class="dashboard-page">
    <main class="dashboard-shell">
        <section class="dashboard-card">
            <span class="eyebrow">Protected Area</span>
            <h1>You're signed in.</h1>
            <p class="dashboard-copy">
                Your session is active and this page is protected by middleware.
            </p>

            <div class="profile-block">
                <p class="profile-label">Signed in as</p>
                <strong><%= user.email %></strong>
            </div>

            <div class="dashboard-actions">
                <a href="/" class="ghost-link">Back to home</a>
                <form action="/logout" method="POST">
                    <button type="submit">Log out</button>
                </form>
            </div>
        </section>
    </main>
</body>
</html>
